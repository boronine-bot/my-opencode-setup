#!/usr/bin/env bash
set -euo pipefail

VERSION="1.0.0"

COMPOSE_FILE=""
OUTPUT_FILE=""
DOMAIN="${COOLIFY_DOMAIN:-}"
UUID="${COOLIFY_RESOURCE_UUID:-}"
DRY_RUN=false

DEFAULT_STATE_FILE="${HOME:-/tmp}/.coolify-magic-state.json"
STATE_FILE="${COOLIFY_STATE_FILE:-$DEFAULT_STATE_FILE}"

usage() {
    cat <<'EOF'
Usage: coolify-magic-env [OPTIONS] [COMPOSE_FILE]

Resolve Coolify magic environment variables in docker-compose files.

Arguments:
  COMPOSE_FILE          Path to docker-compose.yml (default: docker-compose.yml)

Options:
  -d, --domain DOMAIN   Wildcard domain for URL/FQDN generation (env: COOLIFY_DOMAIN)
  -u, --uuid UUID       Resource UUID for URL/FQDN generation (env: COOLIFY_RESOURCE_UUID)
  -o, --output FILE     Write output to FILE instead of stdout
  -s, --state-file FILE Persist generated values to FILE
  -n, --dry-run         Show what would be generated without saving state
  -h, --help            Show this help message

Magic variable syntax:  SERVICE_<TYPE>_<IDENTIFIER>[_<PORT>][=<PATH>]

Types:
  URL                     http://<identifier>-<uuid>.<domain>[/<path>]
  FQDN                    <identifier>-<uuid>.<domain>
  USER                    Random string, 16 chars
  PASSWORD                Random alphanumeric, 32 chars
  PASSWORD_64             Random alphanumeric, 64 chars
  PASSWORDWITHSYMBOLS     Random with symbols, 32 chars
  PASSWORDWITHSYMBOLS_64  Random with symbols, 64 chars
  BASE64 / BASE64_32      Random string, 32 chars
  BASE64_64               Random string, 64 chars
  BASE64_128              Random string, 128 chars
  REALBASE64 / _32        Base64-encoded random, 32 chars
  REALBASE64_64           Base64-encoded random, 64 chars
  REALBASE64_128          Base64-encoded random, 128 chars
  HEX_32                  Hexadecimal random, 32 chars
  HEX_64                  Hexadecimal random, 64 chars
  HEX_128                 Hexadecimal random, 128 chars
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -d|--domain)       DOMAIN="$2"; shift 2 ;;
        --domain=*)        DOMAIN="${1#*=}"; shift ;;
        -u|--uuid)         UUID="$2"; shift 2 ;;
        --uuid=*)          UUID="${1#*=}"; shift ;;
        -o|--output)       OUTPUT_FILE="$2"; shift 2 ;;
        --output=*)        OUTPUT_FILE="${1#*=}"; shift ;;
        -s|--state-file)   STATE_FILE="$2"; shift 2 ;;
        --state-file=*)    STATE_FILE="${1#*=}"; shift ;;
        -n|--dry-run)      DRY_RUN=true; shift ;;
        -h|--help)         usage; exit 0 ;;
        -*)                echo "Error: Unknown option: $1" >&2; usage >&2; exit 1 ;;
        *)                 COMPOSE_FILE="$1"; shift ;;
    esac
done

COMPOSE_FILE="${COMPOSE_FILE:-docker-compose.yml}"

if [[ ! -f "$COMPOSE_FILE" ]]; then
    echo "Error: $COMPOSE_FILE not found" >&2
    exit 1
fi

# -----------------------------------------------------------
# Random value generators
# -----------------------------------------------------------

random_alnum() {
    local len="$1"
    LC_ALL=C tr -dc 'A-Za-z0-9' < /dev/urandom 2>/dev/null | head -c "$len" || true
}

random_alnum_symbols() {
    local len="$1"
    LC_ALL=C tr -dc 'A-Za-z0-9!@#$%^&*()\-_=+[]{}|;:,.<>?/~' < /dev/urandom 2>/dev/null | head -c "$len" || true
}

random_hex() {
    local len="$1"
    openssl rand -hex "$(( (len + 1) / 2 ))" 2>/dev/null | head -c "$len" || true
}

random_base64_str() {
    local len="$1"
    LC_ALL=C tr -dc 'A-Za-z0-9' < /dev/urandom 2>/dev/null | head -c "$len" || true
}

random_realbase64() {
    local len="$1"
    local bytes=$(( (len * 3 + 3) / 4 ))
    openssl rand -base64 "$bytes" 2>/dev/null | tr -d '\n=' | head -c "$len" || true
}

# -----------------------------------------------------------
# State persistence
# -----------------------------------------------------------

_get_state() {
    local key="$1"
    if [[ -f "$STATE_FILE" ]]; then
        grep "^${key}=" "$STATE_FILE" 2>/dev/null | head -1 | cut -d= -f2- || true
    fi
}

_set_state() {
    local key="$1"
    local value="$2"
    if [[ "$DRY_RUN" == true ]]; then
        return
    fi
    local tmpfile
    tmpfile=$(mktemp)
    if [[ -f "$STATE_FILE" ]]; then
        grep -v "^${key}=" "$STATE_FILE" 2>/dev/null > "$tmpfile" || true
    fi
    echo "${key}=${value}" >> "$tmpfile"
    sort "$tmpfile" > "$STATE_FILE" 2>/dev/null || cp "$tmpfile" "$STATE_FILE"
    rm -f "$tmpfile"
}

# -----------------------------------------------------------
# Value generator
# -----------------------------------------------------------

generate_value() {
    local var_name="$1"
    local var_type="$2"
    local identifier="$3"
    local port="$4"
    local path="$5"

    local cached
    cached=$(_get_state "$var_name")
    if [[ -n "$cached" ]]; then
        echo "$cached"
        return
    fi

    local id_lower
    id_lower=$(echo "$identifier" | tr '[:upper:]' '[:lower:]' | tr '_' '-')

    local value=""

    case "$var_type" in
        URL)
            value="http://${id_lower}-${UUID}.${DOMAIN}${path}"
            ;;
        FQDN)
            value="${id_lower}-${UUID}.${DOMAIN}"
            ;;
        USER)
            value=$(random_alnum 16)
            ;;
        PASSWORD)
            value=$(random_alnum 32)
            ;;
        PASSWORD_64)
            value=$(random_alnum 64)
            ;;
        PASSWORDWITHSYMBOLS)
            value=$(random_alnum_symbols 32)
            ;;
        PASSWORDWITHSYMBOLS_64)
            value=$(random_alnum_symbols 64)
            ;;
        BASE64|BASE64_32)
            value=$(random_base64_str 32)
            ;;
        BASE64_64)
            value=$(random_base64_str 64)
            ;;
        BASE64_128)
            value=$(random_base64_str 128)
            ;;
        REALBASE64|REALBASE64_32)
            value=$(random_realbase64 32)
            ;;
        REALBASE64_64)
            value=$(random_realbase64 64)
            ;;
        REALBASE64_128)
            value=$(random_realbase64 128)
            ;;
        HEX_32)
            value=$(random_hex 32)
            ;;
        HEX_64)
            value=$(random_hex 64)
            ;;
        HEX_128)
            value=$(random_hex 128)
            ;;
        *)
            value=""
            ;;
    esac

    _set_state "$var_name" "$value"
    echo "$value"
}

# -----------------------------------------------------------
# Magic variable parsing — sets global vars: P_TYPE P_ID P_PORT P_PATH
# Returns non-zero if not a valid magic var.
# -----------------------------------------------------------

parse_magic_var() {
    local raw="$1"
    local name="${raw%%=*}"
    local eq_val="${raw#*=}"
    [[ "$eq_val" == "$raw" ]] && eq_val=""

    local rest="${name#SERVICE_}"
    [[ "$rest" == "$name" ]] && return 1

    P_TYPE=""
    P_ID=""
    P_PORT=""
    P_PATH=""

    if [[ "$rest" =~ ^(URL|FQDN)_(.+)$ ]]; then
        P_TYPE="${BASH_REMATCH[1]}"
        P_ID="${BASH_REMATCH[2]}"
    elif [[ "$rest" =~ ^(PASSWORDWITHSYMBOLS_64)_(.+)$ ]]; then
        P_TYPE="${BASH_REMATCH[1]}"
        P_ID="${BASH_REMATCH[2]}"
    elif [[ "$rest" =~ ^(PASSWORDWITHSYMBOLS)_(.+)$ ]]; then
        P_TYPE="${BASH_REMATCH[1]}"
        P_ID="${BASH_REMATCH[2]}"
    elif [[ "$rest" =~ ^(PASSWORD_64)_(.+)$ ]]; then
        P_TYPE="${BASH_REMATCH[1]}"
        P_ID="${BASH_REMATCH[2]}"
    elif [[ "$rest" =~ ^(PASSWORD)_(.+)$ ]]; then
        P_TYPE="${BASH_REMATCH[1]}"
        P_ID="${BASH_REMATCH[2]}"
    elif [[ "$rest" =~ ^(USER)_(.+)$ ]]; then
        P_TYPE="${BASH_REMATCH[1]}"
        P_ID="${BASH_REMATCH[2]}"
    elif [[ "$rest" =~ ^(BASE64_128)_(.+)$ ]]; then
        P_TYPE="${BASH_REMATCH[1]}"
        P_ID="${BASH_REMATCH[2]}"
    elif [[ "$rest" =~ ^(BASE64_64)_(.+)$ ]]; then
        P_TYPE="${BASH_REMATCH[1]}"
        P_ID="${BASH_REMATCH[2]}"
    elif [[ "$rest" =~ ^(BASE64_32)_(.+)$ ]]; then
        P_TYPE="${BASH_REMATCH[1]}"
        P_ID="${BASH_REMATCH[2]}"
    elif [[ "$rest" =~ ^(BASE64)_(.+)$ ]]; then
        P_TYPE="BASE64"
        P_ID="${BASH_REMATCH[2]}"
    elif [[ "$rest" =~ ^(REALBASE64_128)_(.+)$ ]]; then
        P_TYPE="${BASH_REMATCH[1]}"
        P_ID="${BASH_REMATCH[2]}"
    elif [[ "$rest" =~ ^(REALBASE64_64)_(.+)$ ]]; then
        P_TYPE="${BASH_REMATCH[1]}"
        P_ID="${BASH_REMATCH[2]}"
    elif [[ "$rest" =~ ^(REALBASE64_32)_(.+)$ ]]; then
        P_TYPE="${BASH_REMATCH[1]}"
        P_ID="${BASH_REMATCH[2]}"
    elif [[ "$rest" =~ ^(REALBASE64)_(.+)$ ]]; then
        P_TYPE="REALBASE64"
        P_ID="${BASH_REMATCH[2]}"
    elif [[ "$rest" =~ ^(HEX_128)_(.+)$ ]]; then
        P_TYPE="${BASH_REMATCH[1]}"
        P_ID="${BASH_REMATCH[2]}"
    elif [[ "$rest" =~ ^(HEX_64)_(.+)$ ]]; then
        P_TYPE="${BASH_REMATCH[1]}"
        P_ID="${BASH_REMATCH[2]}"
    elif [[ "$rest" =~ ^(HEX_32)_(.+)$ ]]; then
        P_TYPE="${BASH_REMATCH[1]}"
        P_ID="${BASH_REMATCH[2]}"
    else
        return 1
    fi

    # For URL/FQDN: extract port from identifier suffix
    if [[ "$P_TYPE" == "URL" || "$P_TYPE" == "FQDN" ]]; then
        if [[ "$P_ID" =~ ^([A-Za-z0-9-]+)_([0-9]+)$ ]]; then
            P_ID="${BASH_REMATCH[1]}"
            P_PORT="${BASH_REMATCH[2]}"
        fi
        P_PATH="$eq_val"
    fi

    return 0
}

# -----------------------------------------------------------
# Extract magic variable references from compose file
# -----------------------------------------------------------

extract_magic_refs() {
    local file="$1"
    grep -oP 'SERVICE_[A-Za-z0-9_]+(=[^[:space:]]*)?' "$file" 2>/dev/null | sort -u || true
}

# -----------------------------------------------------------
# Main
# -----------------------------------------------------------

MAGIC_NAMES=$(extract_magic_refs "$COMPOSE_FILE")

if [[ -z "$MAGIC_NAMES" ]]; then
    echo "# No Coolify magic variables found." >&2
    exit 0
fi

NEED_DOMAIN_UUID=false
while IFS= read -r entry; do
    [[ -z "$entry" ]] && continue
    if [[ "${entry%%=*}" =~ ^SERVICE_(URL|FQDN)_ ]]; then
        NEED_DOMAIN_UUID=true
        break
    fi
done <<< "$MAGIC_NAMES"

if [[ "$NEED_DOMAIN_UUID" == true ]]; then
    if [[ -z "$DOMAIN" || -z "$UUID" ]]; then
        echo "Error: --domain and --uuid are required for URL/FQDN magic variables." >&2
        echo "Set them via CLI flags or COOLIFY_DOMAIN / COOLIFY_RESOURCE_UUID env vars." >&2
        exit 1
    fi
fi

declare -A VAR_OUTPUT

while IFS= read -r raw_name; do
    [[ -z "$raw_name" ]] && continue
    local_name="${raw_name%%=*}"

    # Store raw ref by var name; later entries (with paths) override earlier ones
    VAR_OUTPUT[$local_name]="$raw_name"
done <<< "$MAGIC_NAMES"

GENERATED=""
for local_name in "${!VAR_OUTPUT[@]}"; do
    raw_name="${VAR_OUTPUT[$local_name]}"

    if ! parse_magic_var "$raw_name"; then
        continue
    fi

    val=$(generate_value "$local_name" "$P_TYPE" "$P_ID" "$P_PORT" "$P_PATH")
    GENERATED+="${local_name}=${val}"$'\n'
done

OUTPUT=$(printf '%s' "$GENERATED" | sort)

if [[ -n "$OUTPUT_FILE" ]]; then
    printf '%s\n' "$OUTPUT" > "$OUTPUT_FILE"
    count=$(echo "$OUTPUT" | grep -c '=' || true)
    echo "Wrote ${count:-0} variables to $OUTPUT_FILE" >&2
else
    printf '%s\n' "$OUTPUT"
fi
